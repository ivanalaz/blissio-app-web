# Javni URL sajta (kanonski link za SEO, OG, sitemap)
NEXT_PUBLIC_SITE_URL=https://blissio.app

# Supabase (javni URL — koristi se i na serveru u API ruti)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Samo server (Vercel Environment Variables → Production / Preview)
# Nikada ne stavljaj u klijentski kod ili NEXT_PUBLIC_*
SUPABASE_SERVICE_ROLE_KEY=

# Opciono: ako treba klijentu direktan pristup Supabase-u (trenutno waitlist ide preko API-ja)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
